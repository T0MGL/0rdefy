# ================================================================
# ORDEFY - Environment Variables Template
# ================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ================================================================

# ================================================================
# DATABASE (Supabase)
# ================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ================================================================
# FRONTEND (Vite, prefixed VITE_ to expose to browser)
# ================================================================
VITE_API_URL=https://api.ordefy.io
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SENTRY_DSN=

# ================================================================
# AUTHENTICATION
# ================================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Supabase JWT Secret (Dashboard → Settings → API → JWT Secret).
# Used to mint a second token that authenticates the browser against
# Supabase Realtime. RLS policies resolve auth.uid() from the "sub" claim.
# Required: app cannot start without it (Realtime would silently fail).
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-from-dashboard

# ================================================================
# API SERVER
# ================================================================
API_PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:8080
API_URL=http://localhost:3001

# ================================================================
# N8N AUTOMATION (optional)
# Production base: https://n8n.thebrightidea.ai
# Development fallback: http://localhost:5678/webhook
# CRITICAL: Never deploy with localhost URLs in production.
# The server logs an error at startup if NODE_ENV=production and
# N8N_WEBHOOK_URL still points to localhost.
# ================================================================
N8N_WEBHOOK_URL=https://n8n.thebrightidea.ai/webhook
N8N_API_KEY=
N8N_WEBHOOK_URL_NEWORDER=https://n8n.thebrightidea.ai/webhook/order-create-multitenant

# ================================================================
# SENTRY (error tracking)
# ================================================================
SENTRY_DSN=

# ================================================================
# LOGGING
# Production values: LOG_LEVEL=info, ENABLE_QUERY_LOGGING=false
# Development values: LOG_LEVEL=debug, ENABLE_QUERY_LOGGING=true
# WARNING: debug + true in production leaks data and degrades perf.
# ================================================================
LOG_LEVEL=info
ENABLE_QUERY_LOGGING=false

# ================================================================
# SHOPIFY INTEGRATION
# ================================================================
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_customers,write_customers
SHOPIFY_REDIRECT_URI=http://localhost:3001/api/shopify-oauth/callback
APP_URL=http://localhost:8080
# Token Exchange + auto-provision flow for embedded installs (App Store sprint).
# When true: POST /api/shopify/auth/token-exchange exchanges App Bridge session
# token for an offline access token and auto-provisions user/store/integration.
# When false: legacy OAuth (/api/shopify-oauth/auth) is the only install path.
SHOPIFY_TOKEN_EXCHANGE_ENABLED=false

# ================================================================
# STRIPE (payments and subscriptions)
# ================================================================
STRIPE_PUBLIC_KEY=pk_test_your_public_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
