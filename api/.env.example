# ================================================================
# ORDEFY API - Environment Variables Template
# ================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ================================================================

# ================================================================
# DATABASE (Supabase)
# ================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ================================================================
# FRONTEND (Vite, prefixed VITE_ to expose to browser)
# ================================================================
VITE_API_URL=https://api.ordefy.io
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ================================================================
# AUTHENTICATION
# ================================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ================================================================
# API SERVER
# ================================================================
API_PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:8080
API_URL=http://localhost:3001

# ================================================================
# SENTRY (error tracking)
# ================================================================
SENTRY_DSN=

# ================================================================
# LOGGING
# ================================================================
LOG_LEVEL=debug
ENABLE_QUERY_LOGGING=true

# ================================================================
# SHOPIFY INTEGRATION
# ================================================================
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_customers,write_customers
SHOPIFY_REDIRECT_URI=http://localhost:3001/api/shopify-oauth/callback
APP_URL=http://localhost:8080

# ================================================================
# STRIPE (payments and subscriptions)
# ================================================================
STRIPE_PUBLIC_KEY=pk_test_your_public_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ================================================================
# EMAIL (Resend)
# ================================================================
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Ordefy <noreply@ops.ordefy.io>

# ================================================================
# WHATSAPP VERIFICATION (Meta Business API, optional)
# ================================================================
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFICATION_ENABLED=false
